DATABASE_URL=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Comma-separated frontend origins allowed to receive OAuth callback redirects.
OAUTH_ALLOWED_REDIRECT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set these in production if the API runs behind a public /api route.
# Example: OAUTH_BACKEND_ORIGIN=https://your-domain.com
# Example: OAUTH_CALLBACK_PREFIX=/api/auth
OAUTH_BACKEND_ORIGIN=
OAUTH_CALLBACK_PREFIX=
OAUTH_FRONTEND_CALLBACK_URL=
